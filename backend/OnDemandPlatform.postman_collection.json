            "body": { "mode": "raw", "raw": "{\n  \"id\": \"BOOKING_ID_HERE\",\n  \"status\": \"Completed\",\n  \"start_datetime\": \"2025-12-25T10:00:00\",\n  \"complete_datetime\": \"2025-12-25T14:00:00\"\n}" }
